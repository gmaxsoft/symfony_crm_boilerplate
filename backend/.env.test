KERNEL_CLASS='App\Kernel'
APP_SECRET='venom_test_secret_key_do_not_use_in_prod'
APP_DEBUG=0

# Baza SQLite — nie wymaga uruchomionego MySQL podczas testów
DATABASE_URL="sqlite:///%kernel.project_dir%/var/test.db"

# JWT — klucze z katalogu config/jwt/ (wygenerowane podczas setup)
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=venom_crm_jwt_secret
JWT_TTL=3600

CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
