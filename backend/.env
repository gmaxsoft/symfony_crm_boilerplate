# W każdym środowisku wczytywane są po kolei (ostatni ma wyższy priorytet):
#   .env, .env.local, .env.$APP_ENV, .env.$APP_ENV.local
#
# NIE TRZYMAJ SEKRETÓW PRODUKCYJNYCH W TYM PLIKU.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=venom_crm_change_me_in_production
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# Zmień dane dostępowe do MySQL: mysql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL="mysql://root:root@127.0.0.1:3306/venom_crm?serverVersion=8.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=venom_crm_jwt_secret
JWT_TTL=3600
###< lexik/jwt-authentication-bundle ###

# Na Windows z Herd: ustaw ścieżkę do openssl.cnf jeśli generowanie kluczy JWT zawodzi
# OPENSSL_CONF=C:\Users\YOUR_USER\.config\herd\bin\php83\extras\ssl\openssl.cnf
